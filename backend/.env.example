# Copy this file to .env and fill in your credentials.
# Never commit .env to source control.

# Azure Speech (TTS / STT)
AZURE_SPEECH_API_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Azure OpenAI — GPT deployment
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-05-01-preview

# Google AI — Imagen / Veo
GOOGLE_AI_KEY=your_google_ai_key_here

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=eureka

# CORS — comma-separated origins (defaults to localhost:5173,4173)
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
